# Environment variable overrides for global-captcha /solve.
# Source this file or export these in your shell to override config.yaml.
#
#   set -a; source .env; set +a
#   python3 solver.py
#
# Any var you DON'T set falls back to config.yaml (or config.local.yaml).

# LLM endpoint
CAPTCHA_ROUTER_URL=http://localhost:32128/v1/chat/completions
CAPTCHA_ROUTER_KEY=ABC12345
CAPTCHA_TIMEOUT_S=30

# Model chain
CAPTCHA_PRIMARY=mimo-v2-omni
# CAPTCHA_FALLBACK=gemini-2.5-flash,kimi-k2.5
